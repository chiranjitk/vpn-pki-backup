// IP POOLS
// ============================================

model IpPool {
  id                    String   @id @default(cuid())
  name                  String   @unique
  cidr                  String                       // e.g., 10.70.1.0/24
  gateway               String?                      // Optional gateway IP
  dnsServers            String?                      // Comma-separated DNS servers
  
  // Usage tracking
  usedIps               Int      @default(0)
  totalIps              Int      @default(254)        // Calculated from CIDR
  
  // Status
  status                PoolStatus @default(ACTIVE)
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([name])
  @@index([status])
}

enum PoolStatus {
  ACTIVE
  DISABLED
  DEPLETED
}

// ============================================
// CONNECTION PROFILES (VPN CONFIGURATION)
// ============================================

model ConnectionProfile {
  id                    String   @id @default(cuid())
  
  // Profile Info
  name                  String   @unique               // Unique profile name
  description           String?
  isDefault             Boolean  @default(false)
  isEnabled             Boolean  @default(true)
  
  // Connection Settings
  connectionName        String   @default("ikev2-cert") // Name used in swanctl.conf
  ikeVersion            Int      @default(2)            // 1 or 2
  
  // IKE Proposals (comma-separated, e.g., "aes256-sha256-modp1024")
  ikeProposals          String   @default("aes256-sha256-modp1024,aes256-sha384-modp2048,aes256gcm16-sha256-modp2048")
  
  // ESP Proposals (comma-separated, e.g., "aes256-sha1,aes256-sha256")
  espProposals          String   @default("aes256-sha256,aes256gcm16-sha256")
  
  // Local Authentication Settings
  localAuth             String   @default("pubkey")     // pubkey, eap, psk
  localCert             String   @default("vpn-server.pem")
  localId               String?
  
  // Remote Authentication Settings
  remoteAuth            String   @default("pubkey")     // pubkey, eap-tls, eap-mschapv2
  remoteCaId            String?                         // CA subject for client validation
  remoteEapId           String?                         // EAP identity if using EAP
  
  // IP Pool Settings (can reference IpPool or use inline settings)
  poolId                String?                         // Reference to IpPool
  poolName              String   @default("vpn-pool")
  poolAddressRange      String   @default("10.70.0.0/24")
  dnsServers            String   @default("8.8.8.8,8.8.4.4")
  
  // Traffic Selectors
  localTrafficSelector  String   @default("0.0.0.0/0")
  remoteTrafficSelector String   @default("dynamic")
  
  // Additional Options
  mobike                Boolean  @default(true)
  fragmentation         Boolean  @default(true)
  reauthTime            Int      @default(0)            // 0 = disabled
  dpdTimeout            Int      @default(30)           // DPD timeout in seconds
  dpdAction             String   @default("restart")    // none, clear, restart
  startAction           String   @default("none")       // none, start, add, route, trap
  
  // Server Identity
  serverHostnames       String?                         // Comma-separated hostnames/IPs
  localAddrs            String?                         // Comma-separated local addresses
  
  // StrongSwan Integration
  configApplied         Boolean  @default(false)
  appliedAt             DateTime?
  configPath            String?                         // Path to generated config file
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([name])
  @@index([connectionName])
  @@index([isDefault])
  @@index([isEnabled])
}

