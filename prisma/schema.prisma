// ============================================

model FirewallZone {
  id                    String   @id @default(cuid())
  firewallId            String
  firewall              FirewallIntegration @relation(fields: [firewallId], references: [id], onDelete: Cascade)
  
  // Zone Info
  name                  String
  description           String?
  zoneType              FirewallZoneType @default(L3)
  
  // Network Settings
  interfaces            String?  // JSON array of interface names
  subnets               String?  // JSON array of CIDR notations
  
  // VPN Zone Settings
  isVpnZone             Boolean  @default(false)
  vpnSubnet             String?
  
  // Status
  isEnabled             Boolean  @default(true)
  syncStatus            SyncStatus @default(PENDING)
  lastSyncAt            DateTime?
  syncError             String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([firewallId])
  @@index([isEnabled])
  @@index([isVpnZone])
}

enum FirewallZoneType {
  L3          // Layer 3 zone
  L2          // Layer 2 zone
  TAP         // Tap zone
  EXTERNAL    // External zone
  TUNNEL      // Tunnel zone (for VPN)
}

// ============================================
// FIREWALL SYNC LOG
// ============================================

model FirewallSyncLog {
  id                    String   @id @default(cuid())
  firewallId            String
  firewall              FirewallIntegration @relation(fields: [firewallId], references: [id], onDelete: Cascade)
  
  // Sync Details
  syncType              FirewallSyncType
  startedAt             DateTime @default(now())
  completedAt           DateTime?
  duration              Int?                       // Milliseconds
  
  // Results
  zonesCreated          Int      @default(0)
  zonesUpdated          Int      @default(0)
  zonesDeleted          Int      @default(0)
  policiesCreated       Int      @default(0)
  policiesUpdated       Int      @default(0)
  policiesDeleted       Int      @default(0)
  subnetsSynced         Int      @default(0)
  
  // Status
  status                SyncStatus @default(PENDING)
  errorMessage          String?
  
  // Details (JSON)
  details               String?                    // JSON with detailed results

  @@index([firewallId])
  @@index([startedAt])
  @@index([status])
}

enum FirewallSyncType {
  FULL_SYNC
  ZONE_SYNC
  POLICY_SYNC
  SUBNET_SYNC
  USER_GROUP_SYNC
}

// ============================================
// ACCESS CONTROL POLICIES
// ============================================

model AccessPolicy {
  id                    String   @id @default(cuid())
  
  // Policy Info
  name                  String
  description           String?
  priority              Int      @default(100)
  
  // Match Conditions
  userGroups            String?  // JSON array of group names
  certificateTypes      String?  // JSON array
  deviceTypes           String?  // JSON array
  sourceCountries       String?  // JSON array of country codes
  sourceIpRanges        String?  // JSON array of CIDR
  
  // Time Restrictions
  timeSchedule          String?  // JSON with days/hours
  
  // Actions
  action                PolicyAction @default(ALLOW)
  bandwidthLimit        Int?     // Kbps
  sessionTimeout        Int?     // Minutes
  maxConcurrentSessions Int?
  
  // Destination Restrictions
  allowedDestinations   String?  // JSON array of CIDR
  deniedDestinations    String?  // JSON array of CIDR
  
  // Status
  isEnabled             Boolean  @default(true)
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isEnabled])
  @@index([priority])
}

enum PolicyAction {
  ALLOW
  DENY
  QUARANTINE
  MONITOR
}

// ============================================
// STATIC ROUTES
// ============================================

model StaticRoute {
  id              String   @id @default(cuid())
  destination     String                       // CIDR notation
  gateway         String
  interface       String   @default("eth0")
  metric          Int      @default(100)
  isEnabled       Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isEnabled])
}

// ============================================
// FIREWALL RULES
// ============================================

model FirewallRule {
  id              String   @id @default(cuid())
  name            String
  action          String   @default("ALLOW")      // ALLOW, DENY
  protocol        String   @default("TCP")        // TCP, UDP, ICMP, ALL
  sourcePort      String?
  destPort        String?
  sourceIp        String   @default("0.0.0.0/0")
  destIp          String   @default("0.0.0.0/0")
  interface       String   @default("eth0")
  isEnabled       Boolean  @default(true)
  priority        Int      @default(100)
  description     String?

  // nftables-specific fields
  handle          Int?                             // nftables rule handle
  tableName       String   @default("filter")     // Table name (filter, nat, etc.)
  family          String   @default("inet")       // Table family (inet, ip, ip6)
  chainName       String   @default("input")      // Chain name (input, output, forward, etc.)
  ruleType        String   @default("filter")     // Rule type (filter, nat, forward)

  // Statistics (synced from nftables)
  packets         Int      @default(0)
  bytes           Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isEnabled])
  @@index([priority])
  @@index([tableName])
  @@index([chainName])
  @@index([family])
}

// ============================================
// NAT POLICIES
// ============================================

model NatPolicy {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("SNAT")       // SNAT, DNAT, MASQUERADE
  sourceIp        String   @default("0.0.0.0/0")
  destIp          String   @default("0.0.0.0/0")
  interface       String   @default("eth0")
  translatedIp    String
  isEnabled       Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isEnabled])
}

// ============================================
// RATE LIMITING
// ============================================

model RateLimitConfig {
  id                    String   @id @default(cuid())
  
  // Scope
  scope                 RateLimitScope            // GLOBAL, VPN, API, PER_USER
  name                  String
  
  // Limits
  requestsPerSecond     Int?
  requestsPerMinute     Int?
  requestsPerHour       Int?
  requestsPerDay        Int?
  
  // Burst Settings
  burstSize             Int?                      // Max burst allowed
  burstWindow           Int?                      // Seconds
  
  // Connection Limits
  maxConnections        Int?                      // Max concurrent connections
  maxConnectionsPerIp   Int?
  
  // Action on Limit
  action                RateLimitAction @default(BLOCK)
  blockDuration         Int?                      // Seconds to block
  
  // Whitelist/Bypass
  whitelistIps          String?                   // JSON array of IPs
  whitelistCountries    String?                   // JSON array of country codes
  
  // Status
  isEnabled             Boolean  @default(true)
  
  // Stats
  totalRequests         Int      @default(0)
  totalBlocked          Int      @default(0)
  lastBlockedAt         DateTime?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([scope])
  @@index([isEnabled])
}

enum RateLimitScope {
  GLOBAL          // System-wide rate limiting
  VPN             // VPN connection rate limiting
  API             // API rate limiting
  PER_USER        // Per-user rate limiting
  PER_IP          // Per-IP rate limiting
}

enum RateLimitAction {
  BLOCK           // Block the request
  THROTTLE        // Slow down the request
  LOG_ONLY        // Log but don't block
  CHALLENGE       // Show CAPTCHA or similar
}

// ============================================
// KERNEL FIREWALL (iptables/nftables)
// ============================================

model KernelFirewallRule {
  id                String   @id @default(cuid())
  
  // Rule Info
  name              String
  chain             String   @default("INPUT")      // INPUT, OUTPUT, FORWARD, PREROUTING, POSTROUTING
  table             String   @default("filter")     // filter, nat, mangle, raw
  
  // Match Conditions
  protocol          String?                          // tcp, udp, icmp, all
  sourceIp          String?
  sourcePort        String?
  destIp            String?
  destPort          String?
  inInterface       String?
  outInterface      String?
  
  // Advanced Matches
  tcpFlags          String?                          // SYN,ACK,FIN,RST
  connectionState   String?                          // NEW,ESTABLISHED,RELATED,INVALID
  matchExtensions   String?                          // JSON for additional matches
  
  // Action
  target            String   @default("ACCEPT")      // ACCEPT, DROP, REJECT, LOG, MASQUERADE, SNAT, DNAT
  targetParams      String?                          // Additional parameters for target
  
  // Rule Management
  priority          Int      @default(100)
  isEnabled         Boolean  @default(true)
  isApplied         Boolean  @default(false)         // Whether applied to kernel
  
  // Tracking
  packetsMatched    Int      @default(0)
  bytesMatched      Int      @default(0)
  lastMatchedAt     DateTime?
  
  // Metadata
  description       String?
  isSystemRule      Boolean  @default(false)
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  appliedAt         DateTime?

  @@index([chain])
  @@index([table])
  @@index([isEnabled])
  @@index([isApplied])
  @@index([priority])
}

