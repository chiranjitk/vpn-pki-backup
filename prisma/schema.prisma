  // Features
  enableLogging     Boolean  @default(true)
  enableStateful    Boolean  @default(true)
  
  // Status
  isEnabled         Boolean  @default(true)
  isApplied         Boolean  @default(false)
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  appliedAt         DateTime?

  @@index([isEnabled])
  @@index([isApplied])
}

enum SecurityLevel {
  HIGH             // Most restrictive
  MEDIUM           // Balanced
  LOW              // Less restrictive
  CUSTOM           // Custom rules
}
