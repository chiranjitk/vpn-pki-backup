// ============================================
// FIREWALL INTEGRATION
// ============================================

model FirewallIntegration {
  id                    String   @id @default(cuid())
  
  // Firewall Type
  firewallType          FirewallType
  
  // Connection Settings
  apiUrl                String
  apiKey                String?  // Encrypted
  apiUsername           String?
  apiPassword           String?  // Encrypted
  
  // Palo Alto Specific
  panDeviceGroup        String?
  panVsys               String   @default("vsys1")
  
  // Integration Features
  autoCreateZone        Boolean  @default(false)
  autoCreatePolicy      Boolean  @default(false)
  syncVpnSubnets        Boolean  @default(true)
  syncUserGroups        Boolean  @default(false)
  
  // VPN Zone Settings
  vpnZoneName           String   @default("vpn-zone")
  vpnInterface          String   @default("tunnel.1")
  vpnSubnet             String?
  
  // Status
  isEnabled             Boolean  @default(false)
  lastSyncAt            DateTime?
  lastSyncSuccess       Boolean?
  lastSyncError         String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  zones                 FirewallZone[]
  syncLogs              FirewallSyncLog[]

  @@index([isEnabled])
  @@index([firewallType])
}

enum FirewallType {
  PALO_ALTO
  FORTINET
  CISCO_ASA
  CHECKPOINT
  JUNIPER
  SONICWALL
  CUSTOM
}

// ============================================
