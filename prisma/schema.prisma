  id            String   @id @default(cuid())
  username      String   @unique
  email         String?
  fullName      String?
  department    String?
  phone         String?
  notes         String?
  status        VpnUserStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  certificates  Certificate[]
